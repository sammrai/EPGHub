{
  "name": "epghub-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mock": "tsc -b && VITE_USE_FIXTURES=1 EPGHUB_BASE=${EPGHUB_BASE:-/EPGHub/} vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:api": "openapi-typescript ../server/openapi.yaml -o src/api/epghub.gen.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
