# TVDB v4 API key. Get one at https://thetvdb.com/dashboard/account/apikeys .
# Used by the TVDB adapter when the FixtureTvdbProvider is swapped out.
TVDB_API_KEY=your-tvdb-v4-key-here

# TVDB response cache directory. Login tokens (25d TTL), search results
# (1d), series/movie detail (7d) are persisted here as JSON so that
# restarting the server doesn't re-hit the API. Defaults to /tmp/epghub/tvdb.
TVDB_CACHE_DIR=

# Postgres connection string. Matches docker-compose.yml defaults for dev.
DATABASE_URL=postgresql://epghub:epghub@localhost:5432/epghub

# API server listen port.
PORT=3000

# 実チューナー (Mirakurun) の HTTP エンドポイント。設定すると /channels と
# /schedule が Mirakurun から取得したデータを返す。未設定なら fixtures 駆動。
# 例:  http://192.168.32.71:40772
MIRAKURUN_URL=

# 録画ファイルの出力先ディレクトリ。/system エンドポイントの
# storage.totalBytes / storage.usedBytes はこのパスの statfs から算出する。
# 未設定なら server/.recordings を自動作成して使用する。
RECORDING_DIR=

# Fixture (デモ) モードの制御。`off` なら MIRAKURUN_URL 未設定でも
# サンプル番組 / ルール / チューナーを一切 seed しない。docker-compose.yml
# はこれを `off` にしてデプロイ時に空状態から始めるようにしている。
# ローカル dev で UI のサンプルを見たいときは未設定か `on` にする。
EPGHUB_FIXTURES=
